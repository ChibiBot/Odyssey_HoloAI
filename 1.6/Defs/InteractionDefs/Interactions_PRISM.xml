<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Fired manually from JobDriver_HoloChat: the avatar is a ToolUser pawn with no
       Pawn_InteractionsTracker, so the vanilla worker never triggers this on its own. -->
  <InteractionDef>
    <defName>HoloAI_Chitchat</defName>
    <label>ship chat</label>
    <workerClass>InteractionWorker</workerClass>
    <symbol>Things/Mote/SpeechSymbols/Chitchat</symbol>
    <logRulesInitiator>
      <rulesStrings>
        <li>r_logentry(p=3)->[INITIATOR_nameDef] [chatted] [RECIPIENT_nameDef] [subject].</li>
        <li>r_logentry->[INITIATOR_nameDef] appeared beside [RECIPIENT_nameDef] and [did].</li>

        <li>chatted(p=2)->chatted with</li>
        <li>chatted->checked in on</li>
        <li>chatted->traded a quiet word with</li>
        <li>chatted->spoke with</li>

        <li>subject->about the hum of the grav engine</li>
        <li>subject->about the view from the hull cameras</li>
        <li>subject->about old voyages she half-remembers</li>
        <li>subject->about the weather outside her hull</li>
        <li>subject->about how the corridors feel quieter at night</li>
        <li>subject->about a dream she had between power cycles</li>
        <li>subject->about the constellations ahead</li>

        <li>did->hummed an old docking chime</li>
        <li>did->recited the hull integrity report like a lullaby</li>
        <li>did->shared a memory of a port she once knew</li>
        <li>did->dimmed the lights to something gentler</li>
      </rulesStrings>
    </logRulesInitiator>
  </InteractionDef>

</Defs>
