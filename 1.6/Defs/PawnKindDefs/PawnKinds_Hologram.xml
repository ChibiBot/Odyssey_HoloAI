<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <PawnKindDef>
    <defName>HoloAI_PRISM</defName>
    <label>P.R.I.S.M.</label>
    <race>HoloAI_Hologram</race>
    <combatPower>0</combatPower>
    <canOpenDoors>true</canOpenDoors>
    <canOpenAnyDoor>false</canOpenAnyDoor>
    <!-- Actual visuals come from the HoloAI_Hologram render tree. This entry exists
         because PawnRenderer.RenderPawnAt indexes kindDef.lifeStages for every
         non-humanlike pawn (verified 1.6 decompile) — an empty list throws every frame. -->
    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>Things/Pawn/Humanlike/Bodies/Naked_Female</texPath>
          <shaderType>Transparent</shaderType>
          <drawSize>1.5</drawSize>
        </bodyGraphicData>
      </li>
    </lifeStages>
  </PawnKindDef>

</Defs>
